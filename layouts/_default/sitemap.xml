{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">" | safeHTML }}
{{ range .Data.Pages }}
  {{ printf "\n  <url>" | safeHTML }}
    <loc>{{ .Permalink }}</loc>
    <lastmod>{{ .Lastmod.Format "2006-01-15T15:04:05Z07:00" | safeHTML }}</lastmod>
    {{ if eq .Kind "home" }}
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
    {{ else if eq .Kind "section" }}
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    {{ else if eq .Kind "page" }}
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
    {{ else }}
    <changefreq>weekly</changefreq>
    <priority>0.5</priority>
    {{ end }}
  {{ printf "\n  </url>" | safeHTML }}
{{ end }}
{{ printf "\n</urlset>" | safeHTML }}
