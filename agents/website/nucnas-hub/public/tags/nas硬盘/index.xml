 &lt;td&gt;随机写入&lt;/td&gt;
 &lt;td&gt;优秀&lt;/td&gt;
 &lt;td&gt;较差&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;持续写入稳定性&lt;/td&gt;
 &lt;td&gt;稳定&lt;/td&gt;
